# HMAC key used to sign the public /api/events response. Rotate periodically.
ZDR_FEED_SIGNING_KEY=change-me-to-a-32-byte-random-string

# Path to the cowrie JSON log that T-Pot writes to.
ZDR_COWRIE_LOG_PATH=/data/cowrie/log/cowrie.json

# Path to the MaxMind GeoLite2-City MMDB.
ZDR_GEOIP_DB_PATH=/data/geoip/GeoLite2-City.mmdb

# Ring buffer and window.
ZDR_EVENT_BUFFER_SIZE=500
ZDR_FEED_WINDOW_SECONDS=600

# Bind address (leave 127.0.0.1 behind a reverse proxy, 0.0.0.0 in Docker).
ZDR_HOST=127.0.0.1
ZDR_PORT=8080
